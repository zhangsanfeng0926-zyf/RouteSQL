# Copy this file to scripts/server/server.env and fill values.

# Optional: absolute project root. If empty, inferred from script location.
ROOT_DIR=

# Python executable on server
PYTHON_BIN=python

# LLM config (required)
OPENAI_API_KEY=
OPENAI_BASE_URL=
MODEL=gpt-5

# Repro settings (paper-like high settings)
MAX_SEQ_LEN=10000
K_SHOT=9
TOKENIZER=gpt-3.5-turbo
PROMPT_REPR=SQL
EXAMPLE_TYPE=QA
SELECTOR_STAGE1=EUCDISQUESTIONMASK
SELECTOR_STAGE2=EUCDISMASKPRESKLSIMTHR
N=5
TEMPERATURE=1.0
DB_DIR=dataset/spider/database
# 1 to enable two-stage inference: generate SQL framework first, then fill placeholders.
SQL_FRAMEWORK_FILL=0

# Data config
DATA_TYPE=spider
SPLIT=test

# HuggingFace mirror (optional but recommended in CN network)
HF_ENDPOINT=https://hf-mirror.com
HUGGINGFACE_HUB_BASE_URL=https://hf-mirror.com
HF_HUB_ENABLE_HF_TRANSFER=0
HF_HUB_DISABLE_TELEMETRY=1

# Logs directory relative to ROOT_DIR
LOG_DIR=logs/server
